# Frontend (Vite injects these at build time)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-anon-key-here
VITE_SUPABASE_PROJECT_ID=your-project-id

# Optional: allow Vite dev server to bind to LAN (set to "true" to enable)
# VITE_DEV_LAN=true

# ── Edge Function secrets (set via Lovable Cloud / Supabase dashboard) ──
# SUPABASE_URL          – auto-provided by Supabase runtime
# SUPABASE_SERVICE_ROLE_KEY – auto-provided by Supabase runtime
# SUPABASE_ANON_KEY     – auto-provided by Supabase runtime
# RESEND_API_KEY        – Resend.com API key for transactional email
# LOVABLE_API_KEY       – Lovable AI gateway key (used by parse-import)
# ALLOWED_ORIGINS       – comma-separated list of allowed CORS origins (edge functions)
